# ============================================
# إعدادات الاستضافة - elitevape.online
# انسخ هذا الملف إلى .env على السيرفر
# ============================================

APP_NAME="Elite Vape"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://elitevape.online
APP_MODE=live

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=anagmgxt_elitevape
DB_USERNAME=anagmgxt_elitevape
# كلمة المرور - استخدم القيمة الفعلية عند الرفع (يُفضّل وضعها بين علامتي تنصيص لاحتواء رموز خاصة)
DB_PASSWORD="YOUR_DB_PASSWORD"

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

FORCE_HTTPS=true

# CORS - ضع نطاقات التطبيق مفصولة بفاصلة
CORS_ALLOWED_ORIGINS=https://elitevape.online,https://www.elitevape.online

GUEST_VALIDATE_IP=true
